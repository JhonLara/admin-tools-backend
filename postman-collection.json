          }
        },
        {
          "name": "Aprobar solicitud",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/solicitudes/{{solicitudId}}/aprobar", "host": ["{{baseUrl}}"], "path": ["api", "solicitudes", "{{solicitudId}}", "aprobar"] }
          }
        },
        {
          "name": "Finalizar solicitud",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/solicitudes/{{solicitudId}}/finalizar", "host": ["{{baseUrl}}"], "path": ["api", "solicitudes", "{{solicitudId}}", "finalizar"] }
          }
