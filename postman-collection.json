            "body": {
              "mode": "raw",
              "raw": "{\"cedulaCliente\":\"1234567890\",\"aliadoId\":\"{{aliadoId}}\"}"
            },
            "url": { "raw": "{{baseUrl}}/api/solicitudes", "host": ["{{baseUrl}}"], "path": ["api", "solicitudes"] }
